{
  "name": "cgtjs",
  "module": "cgtjs/index.ts",
  "types": "cgtjs/index.ts",
  "type": "module",
  "version": "0.1.0",
  "files": [
    "cgtjs",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./cgtjs/index.ts",
      "import": "./cgtjs/index.ts",
      "default": "./cgtjs/index.ts"
    },
    "./game": {
      "types": "./cgtjs/game/index.ts",
      "import": "./cgtjs/game/index.ts",
      "default": "./cgtjs/game/index.ts"
    },
    "./solver": {
      "types": "./cgtjs/solver/index.ts",
      "import": "./cgtjs/solver/index.ts",
      "default": "./cgtjs/solver/index.ts"
    },
    "./utils": {
      "types": "./cgtjs/utils/index.ts",
      "import": "./cgtjs/utils/index.ts",
      "default": "./cgtjs/utils/index.ts"
    }
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json --noEmit false",

    "check:ci": "biome ci . --error-on-warnings",
    "check:format": "biome format .",
    "check:lint": "biome lint .",
    "check": "biome check .",

    "fix:format": "biome format --write .",
    "fix:lint": "biome lint --write .",
    "fix": "biome check --write .",

    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",

    "prepare:dist-branch": "bun run build && node scripts/prepare-dist-branch.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.9",
    "@vitest/coverage-v8": "^3.2.4",
    "fast-check": "^4.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4",
    "bun": "^1.3.14"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "trustedDependencies": [
    "bun"
  ]
}
